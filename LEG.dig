      <elementName>Rectangle</elementName>
      <elementAttributes>
        <entry>
          <string>textFontSize</string>
          <int>70</int>
        </entry>
        <entry>
          <string>RectHeight</string>
          <int>124</int>
        </entry>
        <entry>
          <string>Label</string>
          <string>Edge Register</string>
        </entry>
        <entry>
          <string>RectWidth</string>
          <int>90</int>
        </entry>
      </elementAttributes>
      <pos x="-380" y="4140"/>
    </visualElement>
    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>D C L ALWAYS LOADED
# 1. Randomized Startup: Register state is unknown (X). LOADED is 0 because L=0.
0x00 0 0 X 0x00

# 2. Load 0xAA: ALWAYS updates to 0xAA. LOADED shows it because L=1.
0xAA C 1 0xAA 0xAA

# 3. Transparent Check: ALWAYS stays 0xAA. LOADED drops to 0x00 because L=0.
0x55 0 0 0xAA 0x00
0x21 C 0 0x21 0x00

# 5. Load 0x00: Register becomes 0. Both pins show 0.
0x00 C 1 0x00 0x00

# 6. Edge-Triggering: Data 0xEE only moves to ALWAYS on the rising edge.
0xEE 0 1 0x00 0x00  # L=1, but no clock yet; LOADED is 0 because reg is 0
0xEE 1 1 0xEE 0xEE  # Clock goes high; Reg becomes 0xEE. LOADED now shows it.
0xDD 0 1 0xEE 0xEE  # Clock falls; Reg stays 0xEE.

# 7. High-Clock Stability Test
0xAA 0 1 0xEE 0xEE  # Prepare data 0xAA, but clock is 0. ALWAYS stays 0xEE.
0xAA 1 1 0xAA 0xAA  # Clock goes High. Register captures 0xAA.
0xFF 1 1 0xAA 0xAA  # DATA CHANGES TO 0xFF WHILE CLOCK IS STILL HIGH.
                    # ALWAYS MUST STAY 0xAA. If it changes to 0xFF, it&apos;s a latch!
</dataString>
          </testData>
        </entry>
        <entry>
          <string>enabled</string>
          <boolean>false</boolean>
        </entry>
      </elementAttributes>
      <pos x="180" y="5560"/>
    </visualElement>
