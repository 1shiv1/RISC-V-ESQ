    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>Input Right Mask ShiftNum Output
# Edge cases
0x0000 0 0 0  0
0xFFFF 0 0 0  0xFFFF
0x0000 1 0 0  0
0xFFFF 1 0 0  0xFFFF
0x0000 0 1 0  0
0xFFFF 0 1 0  0xFFFF
0xFFFF 0 1 16 0
0xFFFF 1 1 16 0
0x1234 0 0 16 0x1234
0x1234 1 0 16 0x1234
# Randomized
loop(i,1000)
  let in = random(1&lt;&lt;16);
  let sh = random(16);
  (in) 0 0 (sh) (((in&lt;&lt;sh)|(in&gt;&gt;(16-sh)))&amp;0xFFFF)
  (in) 1 0 (sh) (((in&gt;&gt;sh)|(in&lt;&lt;(16-sh)))&amp;0xFFFF)
  (in) 0 1 (sh) ((in&lt;&lt;sh)&amp;0xFFFF)
  (in) 1 1 (sh) ((in&gt;&gt;sh)&amp;0xFFFF)
end loop</dataString>
          </testData>
        </entry>
      </elementAttributes>
